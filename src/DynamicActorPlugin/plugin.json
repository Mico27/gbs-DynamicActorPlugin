{
  "type": "enginePlugin",
  "name": "Dynamic Actor Plugin",
  "author": "Mico27",
  "url": "https://github.com/Mico27/gbs-DynamicActorPlugin",
  "description": "Allows dynamic actor behaviors that requires smooth perpixel movements such as gravity, velocity, actor attached to other actors, etc",
  "license": "MIT",
  "version": "4.3.0",
  "gbsVersion": ">=4.3.0",
  "order": -7,
  "engineAltRules": [
    {
      "when": {
        "additionalPlugins": [
          "Mico27/ContinuousScenePlugin",
          "Mico27/MetaTilePlugin"
        ]
      },
      "use": "ContinuousScenePlugin_MetaTilePlugin"
    },
    {
      "when": {
        "additionalPlugins": [
          "ContinuousScenePlugin",
          "MetaTilePlugin"
        ]
      },
      "use": "ContinuousScenePlugin_MetaTilePlugin"
    },
    {
      "when": {
        "additionalPlugins": [
          "Mico27/ScreenScrollPlugin",
          "Mico27/MetaTilePlugin"
        ]
      },
      "use": "ScreenScrollPlugin_MetaTilePlugin"
    },
    {
      "when": {
        "additionalPlugins": [
          "ScreenScrollPlugin",
          "MetaTilePlugin"
        ]
      },
      "use": "ScreenScrollPlugin_MetaTilePlugin"
    },
    {
      "when": {
        "additionalPlugins": [
          "Mico27/ContinuousScenePlugin"
        ]
      },
      "use": "ContinuousScenePlugin"
    },
    {
      "when": {
        "additionalPlugins": [
          "ContinuousScenePlugin"
        ]
      },
      "use": "ContinuousScenePlugin"
    },
    {
      "when": {
        "additionalPlugins": [
          "Mico27/MetaTilePlugin"
        ]
      },
      "use": "MetaTilePlugin"
    },
    {
      "when": {
        "additionalPlugins": [
          "MetaTilePlugin"
        ]
      },
      "use": "MetaTilePlugin"
    },
    {
      "when": {
        "additionalPlugins": [
          "Mico27/ScreenScrollPlugin"
        ]
      },
      "use": "ScreenScrollPlugin"
    },
    {
      "when": {
        "additionalPlugins": [
          "ScreenScrollPlugin"
        ]
      },
      "use": "ScreenScrollPlugin"
    }
  ]
}
